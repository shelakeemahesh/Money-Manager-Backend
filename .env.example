# -----------------------------------------------------------------------------
# Money Manager Backend — Environment Configuration Template
# Copy this file to `.env` or set these variables in Render / Railway.
# -----------------------------------------------------------------------------

# Server Port (Render automatically sets this)
PORT=8080

# Database Connectivity (MySQL)
# Sourced from Railway or your local MySQL server
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/moneymanager?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=your_db_password

# Database Connection Pool Tuning
# Tuned for Render Free Tier limit (keep it small)
HIKARI_MAX_POOL=5

# JWT Secret Security Config
# MUST be a secure, random string of at least 32 characters (256-bit).
# e.g., generate with: openssl rand -base64 32
APP_JWT_SECRET=your-minimum-32-chars-long-secure-random-secret-key-change-me

# JWT Expiration Time in Milliseconds (Default: 7 days)
APP_JWT_EXPIRATION_MS=604800000

# CORS Configuration (Comma-separated list of allowed frontend origins)
# Set this to your deployed Vercel frontend URL in production
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000

# Application Base API URL
# Used for generating reset-password and activation links sent via email.
# Ensure it ends with /api/v1.0
APP_BASE_URL=http://localhost:8080/api/v1.0

# SMTP Mail Server Integration (Brevo / Sendinblue or Gmail)
BREVO_USERNAME=your-smtp-email@domain.com
BREVO_PASSWORD=your-smtp-api-key-or-password
